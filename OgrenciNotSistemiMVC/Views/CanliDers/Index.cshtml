
@{
    ViewBag.Title = "Index";
    Layout = null;
}



@* Views/OnlineDersMerkezi/Index.cshtml *@
@{
    ViewBag.Title = "Online Ders Merkezi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

   
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

   
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">

 

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f5f5;
            margin: 0;
            padding: 0;
        }

       
        .navbar {
            background-color: #1e1e2f;
            padding: 15px 30px;
        }
        .navbar-brand {
            color: #fff;
            font-weight: 700;
            font-size: 1.6rem;
        }

        
        .content {
            padding: 40px 30px;
        }

     
        .card-ders {
            border-radius: 20px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
            transition: transform 0.3s, box-shadow 0.3s;
            min-height: 180px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            background-color: #fff;
        }
        .card-ders:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.2);
        }

       
        .btn-primary {
            border-radius: 12px;
            padding: 10px 0;
            font-weight: 600;
            transition: 0.3s;
        }
        .btn-primary:hover {
            transform: scale(1.03);
        }

       
        .search-filter {
            margin-bottom: 30px;
        }

      
    </style>
</head>
<body>

   
    <nav class="navbar">
        <a class="navbar-brand" href="#">Online Ders Merkezi</a>
    </nav>

 
    <div class="container-fluid content">

        <
        <div class="row search-filter">
            <div class="col-md-6 mb-3">
                <input type="text" class="form-control" placeholder="Ders ara...">
            </div>
            <div class="col-md-3 mb-3">
                <select class="form-select">
                    <option>Tümü</option>
                    <option>Canlı</option>
                    <option>Geçmiş</option>
                </select>
            </div>
        </div>

    
        <div class="row g-4">
            
            <div class="col-md-4">
                <div class="card card-ders p-4">
                    <h5 class="text-muted">Ders Adı</h5>
                    <p class="text-muted mb-1">Öğretmen: -</p>
                    <p class="text-muted mb-3">Tarih: -</p>
                    <button class="btn btn-primary w-100">Derse Katıl</button>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-ders p-4">
                    <h5 class="text-muted">Ders Adı</h5>
                    <p class="text-muted mb-1">Öğretmen: -</p>
                    <p class="text-muted mb-3">Tarih: -</p>
                    <button class="btn btn-primary w-100">Derse Katıl</button>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-ders p-4">
                    <h5 class="text-muted">Ders Adı</h5>
                    <p class="text-muted mb-1">Öğretmen: -</p>
                    <p class="text-muted mb-3">Tarih: -</p>
                    <button class="btn btn-primary w-100">Derse Katıl</button>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>