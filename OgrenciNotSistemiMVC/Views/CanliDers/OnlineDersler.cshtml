
@{
    ViewBag.Title = "OnlineDersler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<form method="post">
    <input type="text" name="DersAdi" placeholder="Ders Adı" class="form-control" />

    <textarea name="Aciklama" placeholder="Açıklama" class="form-control"></textarea>

    <input type="datetime-local" name="BaslangicTarihi" class="form-control" />
    <input type="datetime-local" name="BitisTarihi" class="form-control" />

    <input type="text" name="MeetingLink" placeholder="Zoom / Meet Link" class="form-control" />

    <input type="text" name="VideoUrl" placeholder="Kayıt Linki (opsiyonel)" class="form-control" />

    <button class="btn btn-success">Kaydet</button>
</form>

