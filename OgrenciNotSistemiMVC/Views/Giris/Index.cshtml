
@{
    Layout = null;
}
@{
    ViewBag.Title = "Index";

}




<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: #f4f6f9;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .panel-box {
        background: white;
        padding: 600px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        text-align: center;
    }

    .card-option {
        padding: 30px;
        border-radius: 20px;
        transition: 0.3s;
        cursor: pointer;
    }

        .card-option:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .icon {
        font-size: 50px;
        margin-bottom: 15px;
    }

    .ogrenci {
        background: #e3f2fd;
        color: #0d6efd;
    }

    .ogretmen {
        background: #fff3cd;
        color: #ff9800;
    }
</style>
</head>

<body>

    <div class="panel-box">

        <h2 class="mb-4"> MVC NOT SİSTEMİ</h2>
        <p class="text-muted mb-5">Lütfen giriş yapmak istediğiniz alanı seçin</p>

        <div class="row">

           
            <div class="col-md-6">
                <a href="/Ogrenci/Index" style="text-decoration:none;">
                    <div class="card-option ogrenci">
                        <div class="icon">
                            <i class="fas fa-user-graduate"></i>
                        </div>
                        <h4>Öğrenci Girişi</h4>
                    </div>
                </a>
            </div>

          
            <div class="col-md-6">
                <a href="/Ogretmen/Index" style="text-decoration:none;">
                    <div class="card-option ogretmen">
                        <div class="icon">
                            <i class="fas fa-chalkboard-teacher"></i>
                        </div>
                        <h4>Öğretmen Girişi</h4>
                    </div>
                </a>
            </div>

        </div>

    </div>

</body>
</html>