@using OgrenciNotSistemiMVC.Models.EntityFramework;
@model List<TBL_KULUPLER>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<table class="table table-striped table-hover align-middle text-center shadow-sm rounded border-0">
<thead class="bg-primary text-white">
    <tr>
        <th scope="col">KULÜP ID</th>
        <th scope="col">KULÜP ADI</th>
        <th scope="col">KULÜP KONTENJAN</th>
    </tr>
</thead>
<tbody>
    @foreach (var klp in Model)
    {
        <tr class="table-row">
            <td>@klp.KULUPID</td>
            <td>@klp.KULUPAD</td>
            <td>@klp.KULUPKONTENJAN</td>
        </tr>
    }
</tbody>
</table>
<a href="/Kulup/YeniKulup" class="btn btn-primary">
    <i class="fas fa-plus me-2"></i> Yeni Kulüp Kaydı
</a>