@model OgrenciNotSistemiMVC.Models.EntityFramework.TBL_OGRENCILER
@using PagedList.Mvc;
@using PagedList;


@{
    ViewBag.Title = "Öğrenci Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form action="/Ogrenci/OgrenciEkle" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label>Öğrenci Adı</label>
        <input type="text" class="form-control" asp-for="OGRENCIAD" />
    </div>

    <div class="mb-3">
        <label>Öğrenci Soyadı</label>
        <input type="text" class="form-control" asp-for="OGRENCISOYAD" />
    </div>

    <div class="mb-3">
        <label>Öğrenci Fotoğrafı</label>
        <input type="file" class="form-control" name="OgrFoto" />
    </div>

    <div class="mb-3">
        <label>Öğrenci Cinsiyeti</label>
        <select class="form-select" asp-for="OGRENCICINSIYET">
            <option value="">Seçiniz</option>
            <option value="Erkek">Erkek</option>
            <option value="Kız">Kız</option>
            <option value="Diğer">Diğer</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Kulüp Seçiniz</label>
        <select class="form-select" asp-for="OGRENCIKULUP" asp-items="ViewBag.Kulupler">
            <option value="">Seçiniz</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">
        <i class="fas fa-user-plus me-2"></i> Ekle
    </button>
</form>