
@{
    ViewBag.Title = "OgretmenLogin";
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: #f4f6f9;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .panel-box {
        background: white;
        padding: 40px 30px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        width: 400px;
        text-align: center;
    }

        .panel-box h2 {
            margin-bottom: 20px;
        }

    .input-group-text {
        background: #e9ecef;
        border-radius: 0.375rem;
    }

    .btn-login {
        width: 100%;
        margin-top: 15px;
    }

    a {
        text-decoration: none;
    }
</style>

<div class="panel-box">
    <h2>Öğretmen Girişi</h2>
    <p class="text-muted mb-4">  Lütfen Kullanıcı Adı Ve Şifrenizle Giriş Yapın </p>

    @if (ViewBag.Hata != null)
    {
        <div class="alert alert-danger">@ViewBag.Hata</div>
    }
    @if (TempData["Mesaj"] != null)
    {
        <div class="alert alert-success">@TempData["Mesaj"]</div>
    }

    <form method="post" action="@Url.Action("OgretmenLogin","OgretmenGiris")">

        <div class="mb-3">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-user-graduate"></i></span>
                <input type="text" name="ogrNo" class="form-control" placeholder="Kullanıcı Adı" required />
            </div>
        </div>

        <div class="mb-3">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-lock"></i></span>
                <input type="password" name="sifre" class="form-control" placeholder="Şifre" required />
            </div>
        </div>

        <button type="submit" class="btn btn-primary btn-login">Giriş Yap</button>
    </form>

    <div class="mt-3">
        <a href="@Url.Action("SifreUnuttum","Giris")">Şifremi Unuttum?</a>
    </div>
</div>

